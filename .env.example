# Zerodha Kite Credentials
# Get these from your Zerodha account
KITE_USER_ID=AB1234
KITE_PASSWORD=your_password_here
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here

# TOTP Secret for 2FA
# This is the secret key from your authenticator app
# Format: Base32 string (A-Z, 2-7)
KITE_TOTP_KEY=ABCDEFGHIJKLMNOPQRSTUVWXYZ234567

# Telegram Bot Configuration
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=123456789

# Kill Switch Thresholds
# You can use either PERCENTAGE or FIXED AMOUNT (Rupees)
# If percentage is set, it will be used; otherwise fixed amount is used

# Loss threshold: Maximum loss before trigger
LOSS_THRESHOLD_PERCENT=10
# LOSS_THRESHOLD=4000

# Profit threshold: Profit level to start tracking for drawdown
PROFIT_THRESHOLD_PERCENT=12.5
# PROFIT_THRESHOLD=5000

# Drawdown threshold: Maximum drawdown from peak profit (as percentage of peak)
DRAWDOWN_THRESHOLD_PERCENT=40
# DRAWDOWN_THRESHOLD=2000

# Trading Capital (required for percentage calculations)
CAPITAL=40000

# Optional: Logging Level
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
